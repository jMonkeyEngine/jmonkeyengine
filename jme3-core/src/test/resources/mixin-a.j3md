MaterialDef MixinA {
    MaterialParameters {
        Float AlphaDiscardThreshold
        Int NumberOfBones
    }
    Technique PreShadow {
        VertexShader GLSL150 GLSL100 : shadow.vert
        FragmentShader GLSL150 GLSL100 : shadow.frag
        WorldParameters {
            WorldViewProjectionMatrix
        }
    }
}
